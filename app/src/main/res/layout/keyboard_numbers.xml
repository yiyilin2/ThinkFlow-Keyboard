<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#D1D4D9"
    android:orientation="vertical"
    android:paddingBottom="45dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="10dp" android:background="#FFFFFF">
        <EditText android:id="@+id/et_english_input" android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="48dp" android:background="@drawable/edittext_rounded" android:hint="Type to translate" android:padding="12dp" android:inputType="textMultiLine" android:focusable="false" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="4dp"
        android:weightSum="5"> <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">
        <Button style="@style/NumKeyGray" android:text="%" android:layout_width="match_parent" android:layout_height="55dp"/>
        <Button style="@style/NumKeyGray" android:text="/" android:layout_width="match_parent" android:layout_height="55dp"/>
        <Button style="@style/NumKeyGray" android:text="-" android:layout_width="match_parent" android:layout_height="55dp"/>
        <Button style="@style/NumKeyGray" android:text="+" android:layout_width="match_parent" android:layout_height="55dp"/>
    </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="4"
            android:orientation="vertical">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <Button style="@style/NumKeyWhite" android:text="1" />
                <Button style="@style/NumKeyWhite" android:text="2" />
                <Button style="@style/NumKeyWhite" android:text="3" />
                <Button android:id="@+id/btn_backspace" style="@style/NumKeyGray" android:text="⌫" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <Button style="@style/NumKeyWhite" android:text="4" />
                <Button style="@style/NumKeyWhite" android:text="5" />
                <Button style="@style/NumKeyWhite" android:text="6" />
                <Button style="@style/NumKeyGray" android:text="." />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <Button style="@style/NumKeyWhite" android:text="7" />
                <Button style="@style/NumKeyWhite" android:text="8" />
                <Button style="@style/NumKeyWhite" android:text="9" />
                <Button style="@style/NumKeyGray" android:text="\@" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <Button android:id="@+id/btn_return_abc" style="@style/NumKeyGray" android:text="返回" />
                <Button style="@style/NumKeyWhite" android:text="0" />
                <Button android:id="@+id/btn_space" style="@style/NumKeyGray" android:text="—" />
                <Button style="@style/NumKeyGray" android:text="↵" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>